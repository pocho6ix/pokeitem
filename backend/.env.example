# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:****@ep-xxx.neon.tech/neondb?sslmode=require

# ─── AUTH ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://app.pokeitem.fr

# ─── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── STRIPE ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID_ANNUAL=price_xxx

# ─── BREVO ────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_EMAIL=contact@pokeitem.fr
BREVO_SENDER_NAME=PokeItem
BREVO_LIST_ID_USERS=
BREVO_LIST_ID_NEWSLETTER=
BREVO_TEMPLATE_WELCOME=
BREVO_TEMPLATE_VERIFY_EMAIL=
BREVO_TEMPLATE_RESET_PASSWORD=
BREVO_TEMPLATE_TRADE_REQUEST=
BREVO_WEBHOOK_SECRET=

# ─── VERCEL BLOB (avatars) ───────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# ─── ANTHROPIC (scanner AI) ──────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_SCANNER=

# ─── CARDMARKET ───────────────────────────────────────────────
CARDMARKET_API_KEY=

# ─── EMAIL ────────────────────────────────────────────────────
EMAIL_FROM=contact@pokeitem.fr

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.pokeitem.fr,capacitor://localhost,http://localhost

# ─── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
